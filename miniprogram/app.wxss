page {
  background: #f6f7f9;
  color: #1f2329;
  font-size: 28rpx;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-shell {
  min-height: 100vh;
}

.sticky-shell {
  position: sticky;
  top: 0;
  z-index: 10;
  background: #f6f7f9;
  padding-top: 12rpx;
}

.panel {
  margin: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.3;
}

.section-subtitle {
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.legend-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.legend-image {
  width: 56rpx;
  height: 56rpx;
  flex: 0 0 auto;
}

.legend-image--small {
  width: 40rpx;
  height: 40rpx;
}

.search-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #d8dee6;
  border-radius: 18rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.search-trigger__placeholder {
  color: #98a2b3;
  font-size: 24rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.line-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 14rpx;
  background: #f3f4f6;
  color: #344054;
  font-size: 24rpx;
}

.line-chip--active {
  box-shadow: inset 0 0 0 4rpx rgba(15, 23, 42, 0.22);
  font-weight: 700;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 18rpx;
  background: #111827;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-button--disabled {
  background: #c7ced9;
}

.result-scroll {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.result-scroll--route {
  padding-bottom: 24rpx;
}

.list-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 16rpx 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.list-card--active {
  border: 2rpx solid #111827;
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.08);
}

.list-card--flat {
  box-shadow: none;
  border-bottom: 2rpx solid #eef2f6;
}

.list-card__main {
  flex: 1;
  min-width: 0;
}

.list-card__title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.list-card__meta {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.icon-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 10rpx;
}

.empty-state {
  margin: 80rpx 24rpx;
  text-align: center;
  color: #98a2b3;
}

.status-block {
  margin: 20rpx 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.6;
}

.status-block--error {
  color: #b42318;
  background: #fef3f2;
}

.route-filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 16rpx;
}

.route-filter-row--header {
  margin-top: 0;
  margin-bottom: 8rpx;
}

.route-filter-label {
  flex: 1;
  min-width: 0;
}

.route-filter-trigger {
  min-width: 220rpx;
  padding: 12rpx 18rpx;
  border: 2rpx solid #d8dee6;
  border-radius: 14rpx;
  background: #ffffff;
  color: #344054;
  font-size: 24rpx;
  text-align: center;
}

.picker-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  background: rgba(15, 23, 42, 0.42);
}

.picker-sheet {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 72vh;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.picker-header {
  padding: 24rpx;
  border-bottom: 2rpx solid #eef2f6;
}

.picker-tabs {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.picker-tab {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f2f4f7;
  color: #667085;
  font-size: 24rpx;
}

.picker-tab--active {
  background: #111827;
  color: #ffffff;
}

.picker-input {
  width: 100%;
  min-height: 84rpx;
  padding: 0 22rpx;
  border: 2rpx solid #d8dee6;
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.picker-input-wrap {
  position: relative;
}

.picker-clear {
  position: absolute;
  top: 50%;
  right: 20rpx;
  transform: translateY(-50%);
  color: #98a2b3;
  font-size: 24rpx;
  z-index: 2;
  padding: 8rpx 4rpx 8rpx 12rpx;
}

.picker-body {
  flex: 1;
  min-height: 0;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx;
  border-bottom: 2rpx solid #f2f4f7;
}

.picker-item__content {
  flex: 1;
  min-width: 0;
}

.picker-item__aside {
  margin-left: 24rpx;
  flex: 0 0 auto;
}

.picker-chip-row {
  justify-content: flex-end;
}

.picker-scroll {
  height: 100%;
}

.picker-item__title {
  font-size: 28rpx;
  font-weight: 600;
}

.picker-item__meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 22rpx;
}

.line-selector-layout {
  display: flex;
  height: 100%;
  min-height: 0;
}

.line-selector-sidebar {
  width: 220rpx;
  border-right: 2rpx solid #eef2f6;
  background: #fafafa;
}

.line-selector-main {
  flex: 1;
  min-height: 0;
}

.line-selector-line {
  padding: 22rpx 20rpx;
  border-bottom: 2rpx solid #eef2f6;
  font-size: 26rpx;
  color: #475467;
}

.line-selector-line--active {
  background: #ffffff;
  color: #111827;
  font-weight: 600;
}

.page-heading {
  margin: 6rpx 24rpx 0;
  font-size: 24rpx;
  color: #667085;
}

.page-shell--column {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

.split-layout {
  display: flex;
  height: calc(100vh - 364rpx);
}

.browse-sidebar {
  width: 200rpx;
  background: #ffffff;
  border-right: 2rpx solid #eef2f6;
}

.browse-main {
  flex: 1;
}

.browse-tab {
  padding: 26rpx 16rpx;
  border-bottom: 2rpx solid #eef2f6;
  color: #475467;
  font-size: 26rpx;
  text-align: center;
  background: #ffffff;
}

.browse-tab--active {
  background: #f8fafc;
  color: #111827;
  font-weight: 600;
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.section-header__main {
  flex: 1;
  min-width: 0;
}

.section-header__aside {
  flex: 0 0 auto;
  text-align: right;
}

.section-header__meta {
  color: #344054;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
}

.section-header__meta--muted {
  color: #667085;
  font-weight: 400;
}

.subtle-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 600;
}

.info-banner {
  margin: 0 24rpx 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #eff6ff, #f8fafc);
  color: #475467;
  font-size: 24rpx;
  line-height: 1.6;
}

.metric-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.metric-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #344054;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.metric-pill--warm {
  background: #fff7ed;
  color: #c2410c;
}

.metric-pill--success {
  background: #ecfdf3;
  color: #027a48;
}

.list-card__subtitle {
  margin-top: 10rpx;
  color: #475467;
  font-size: 24rpx;
  line-height: 1.5;
}

.list-card__meta-inline {
  flex: 0 0 auto;
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.5;
  white-space: nowrap;
}

.detail-entry {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  width: 100%;
}

.detail-entry__content {
  flex: 1;
  min-width: 0;
}

.detail-entry__icons {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.detail-entry__aside {
  flex: 0 0 auto;
  text-align: right;
}

.comments-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fffefe, #fffaf6);
  border: 2rpx solid #f4e7db;
}

.comment-input-bar {
  display: flex;
  align-items: center;
  min-height: 84rpx;
  margin-top: 20rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #f2e8df;
  color: #98a2b3;
  font-size: 24rpx;
}

.comment-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f6ebe2;
}

.comment-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.comment-item__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.comment-item__user {
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 600;
}

.comment-item__time {
  color: #98a2b3;
  font-size: 22rpx;
}

.comment-item__content {
  margin-top: 14rpx;
  color: #344054;
  font-size: 26rpx;
  line-height: 1.7;
}

.comment-item__image {
  width: 100%;
  margin-top: 18rpx;
  border-radius: 18rpx;
}

.comment-item__actions {
  display: flex;
  gap: 24rpx;
  margin-top: 18rpx;
  color: #667085;
  font-size: 22rpx;
}
