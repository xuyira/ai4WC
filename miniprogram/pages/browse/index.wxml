<view class="page-shell">
  <view class="page-heading">顶部搜索始终按全网范围检索，左侧线路筛选仅影响默认列表。</view>
  <view class="sticky-shell">
    <view class="panel">
      <input class="picker-input" placeholder="搜索站点（始终按全网范围）" value="{{searchKeyword}}" bindinput="handleSearchInput" />
      <view wx:if="{{searchKeyword}}" style="margin-top:16rpx;">
        <view class="chip-row" style="justify-content:space-between; align-items:center;">
          <text class="section-subtitle" style="margin-top:0;">搜索结果</text>
          <text style="color:#667085; font-size:24rpx;" bindtap="handleClearSearch">清空</text>
        </view>
        <block wx:for="{{searchResults}}" wx:key="stationId">
          <view class="picker-item" bindtap="handleOpenStation" data-station-id="{{item.stationId}}">
            <view>
              <view class="picker-item__title">{{item.displayName}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>
    <view class="panel">
      <view class="section-title" style="font-size:28rpx;">图例</view>
      <view class="legend-grid">
        <block wx:for="{{legends}}" wx:key="key">
          <view class="legend-item">
            <view class="legend-icon {{item.color}} {{item.type}}"></view>
            <text>{{item.label}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="split-layout">
    <scroll-view scroll-y class="browse-sidebar">
      <view class="browse-tab {{activeTab === 'all' ? 'browse-tab--active' : ''}}" bindtap="handleSelectAll">
        全部
      </view>
      <block wx:for="{{browseData.lines}}" wx:key="lineNo">
        <view class="browse-tab {{activeLineNo === item.lineNo ? 'browse-tab--active' : ''}}" bindtap="handleSelectLine" data-line-no="{{item.lineNo}}">
          {{item.lineLabel}}
        </view>
      </block>
    </scroll-view>

    <scroll-view scroll-y class="browse-main">
      <block wx:for="{{displayStations}}" wx:key="stationId">
        <view class="list-card" bindtap="handleOpenStation" data-station-id="{{item.stationId}}">
          <view class="list-card__main">
            <view class="list-card__title">{{item.stationName}}</view>
            <view class="list-card__meta">{{item.stationLineLabels ? item.stationLineLabels.join(' / ') : item.lineLabels.join(' / ')}}</view>
          </view>
          <view class="icon-row">
            <block wx:for="{{item.legendTypes}}" wx:key="*this">
              <view class="legend-icon {{item.includes('inside_outside') ? 'both' : item.includes('outside') ? 'outside' : 'inside'}} {{item.includes('accessible') ? 'accessible' : 'toilet'}}"></view>
            </block>
          </view>
        </view>
      </block>
      <view wx:if="{{displayStations.length === 0}}" class="empty-state">
        {{emptyText}}
      </view>
    </scroll-view>
  </view>
</view>
