<view class="page-shell page-shell--column">
  <view class="sticky-shell">
    <view class="panel">
      <view class="section-title">上海地铁卫生间指南</view>
      <view class="section-subtitle" style="margin-top:24rpx;">起始站</view>
      <view class="search-trigger" bindtap="openPicker" data-target="start">
        <text>{{startStation ? startStation.selectedLabel : '请选择站点'}}</text>
        <text class="search-trigger__placeholder">搜索 / 按线路选择</text>
      </view>
      <view class="section-subtitle" style="margin-top:24rpx;">终点站</view>
      <view class="search-trigger" bindtap="openPicker" data-target="end">
        <text>{{endStation ? endStation.selectedLabel : '请选择站点'}}</text>
        <text class="search-trigger__placeholder">搜索 / 按线路选择</text>
      </view>
      <view class="primary-button {{isLoadingRoutes ? 'primary-button--disabled' : ''}}" style="margin-top:24rpx;" bindtap="handleSearch">
        {{isLoadingRoutes ? '查询中...' : '查询沿途卫生间'}}
      </view>
    </view>

    <view class="panel" style="padding-top:20rpx;">
      <view class="section-title" style="font-size:28rpx;">图例</view>
      <view class="legend-grid">
        <block wx:for="{{legends}}" wx:key="key">
          <view class="legend-item">
            <image class="legend-image" src="{{item.iconPath}}" mode="aspectFit" />
            <text>{{item.label}}</text>
          </view>
        </block>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="result-scroll result-scroll--route">
    <view wx:if="{{routeError}}" class="status-block {{routeSource === 'mock' ? 'status-block--error' : ''}}">
      {{routeSource === 'mock' ? '官方路线接口暂不可用，当前展示示例路线。' : routeError}}
    </view>

    <view wx:if="{{isLoadingRoutes}}" class="empty-state">正在获取上海地铁官方可行路线...</view>

    <view wx:if="{{routeCandidates.length}}" class="panel">
      <view class="section-title" style="font-size:30rpx;">可行路线</view>
      <block wx:for="{{routeCandidates}}" wx:key="id">
        <view class="list-card {{activeRouteId === item.id ? 'list-card--active' : ''}}" bindtap="handleSelectRoute" data-route-id="{{item.id}}">
          <view class="list-card__main">
            <view class="list-card__title">{{item.summary}}</view>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{routeToiletStations.length}}" class="panel">
      <view class="section-title" style="font-size:30rpx;">沿途卫生间站点</view>
      <view class="route-filter-row">
        <view class="section-subtitle route-filter-label" style="margin-top:0;">沿途卫生间信息</view>
        <picker mode="selector" range="{{routeStationFilterOptions}}" range-key="label" value="{{routeStationFilterIndex}}" bindchange="handleRouteStationFilterChange">
          <view class="route-filter-trigger">{{routeStationFilterOptions[routeStationFilterIndex].label}}</view>
        </picker>
      </view>
      <block wx:for="{{routeToiletStations}}" wx:key="stationId">
        <view class="list-card" bindtap="handleOpenStation" data-station-id="{{item.stationId}}" data-line-no="{{item.currentLineNo}}">
          <view class="list-card__main">
            <view class="list-card__title">{{item.stationName}}</view>
            <view class="chip-row" style="margin-top:10rpx;">
              <block wx:for="{{item.stationLineChips}}" wx:key="lineLabel">
                <view class="line-chip" style="{{item.style}}">{{item.lineLabel}}</view>
              </block>
            </view>
          </view>
          <view class="icon-row">
            <block wx:for="{{item.legendIcons}}" wx:key="key">
              <image class="legend-image legend-image--small" src="{{item.iconPath}}" mode="aspectFit" />
            </block>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{routeCandidates.length && !routeToiletStations.length}}" class="empty-state">该路线沿途暂无可展示卫生间站点。</view>

    <view wx:if="{{!routeCandidates.length && !isLoadingRoutes && !routeError}}" class="empty-state">选择起点和终点后可查看路线候选与沿途卫生间。</view>
  </scroll-view>

  <view wx:if="{{pickerVisible}}" class="picker-mask" bindtap="closePicker">
    <view class="picker-sheet" catchtap="noop">
      <view class="picker-header">
        <view class="section-title" style="font-size:30rpx;">{{pickerTarget === 'start' ? '选择起始站' : '选择终点站'}}</view>
        <view class="picker-tabs">
          <view class="picker-tab {{pickerMode === 'search' ? 'picker-tab--active' : ''}}" bindtap="handleSwitchPickerMode" data-mode="search">打字搜索</view>
          <view class="picker-tab {{pickerMode === 'line' ? 'picker-tab--active' : ''}}" bindtap="handleSwitchPickerMode" data-mode="line">按线路选择</view>
        </view>
      </view>

      <view wx:if="{{pickerMode === 'search'}}" class="picker-body">
        <view class="picker-input-wrap" style="padding:24rpx;">
          <input class="picker-input" placeholder="输入站点名称" value="{{pickerKeyword}}" bindinput="handlePickerKeywordInput" />
          <text wx:if="{{pickerKeyword}}" class="picker-clear" catchtap="handleClearPickerKeyword">清空</text>
        </view>
        <scroll-view scroll-y class="picker-scroll">
          <block wx:for="{{pickerSuggestions}}" wx:key="stationId">
            <view class="picker-item" bindtap="handleChooseRouteStation" data-index="{{index}}" data-source="search">
              <view class="picker-item__content">
                <view class="picker-item__title">{{item.stationName}}</view>
              </view>
              <view class="picker-item__aside">
                <view class="chip-row picker-chip-row">
                  <view class="line-chip" style="{{item.lineChip.style}}">{{item.lineChip.lineLabel}}</view>
                </view>
              </view>
            </view>
          </block>
          <view wx:if="{{!pickerKeyword && !pickerSuggestions.length}}" class="empty-state" style="margin-top:120rpx;">输入站点名称后显示匹配结果</view>
          <view wx:elif="{{pickerKeyword && !pickerSuggestions.length}}" class="empty-state" style="margin-top:120rpx;">没有找到匹配站点</view>
        </scroll-view>
      </view>

      <view wx:if="{{pickerMode === 'line'}}" class="picker-body line-selector-layout">
        <scroll-view scroll-y class="line-selector-sidebar">
          <block wx:for="{{pickerLines}}" wx:key="lineNo">
            <view class="line-selector-line {{pickerActiveLineNo === item.lineNo ? 'line-selector-line--active' : ''}}" style="{{item.lineStyle}}" bindtap="handleSelectPickerLine" data-line-no="{{item.lineNo}}">
              {{item.lineLabel}}
            </view>
          </block>
        </scroll-view>
        <scroll-view scroll-y class="line-selector-main">
          <block wx:for="{{pickerLineStations}}" wx:key="stationId">
            <view class="picker-item" bindtap="handleChooseRouteStation" data-index="{{index}}" data-source="line">
              <view class="picker-item__content">
                <view class="picker-item__title">{{item.stationName}}</view>
              </view>
            </view>
          </block>
        </scroll-view>
      </view>
    </view>
  </view>
</view>
