<view class="page-shell">
  <view wx:if="{{isLoading}}" class="empty-state">正在加载站点详情...</view>

  <view wx:if="{{stationDetail}}" class="panel">
    <view class="section-header">
      <view class="section-header__main">
        <view class="section-title">{{stationDetail.stationName}}</view>
        <view class="chip-row" style="margin-top:20rpx;">
          <block wx:for="{{stationDetail.lineChips}}" wx:key="lineLabel">
            <view class="line-chip" style="{{item.style}}">{{item.lineLabel}}</view>
          </block>
        </view>
      </view>
      <view class="section-header__aside" wx:if="{{stationDetail.fromStartText}}">
        <view class="section-header__meta section-header__meta--muted">{{stationDetail.fromStartText}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{stationDetail}}" class="panel">
    <view class="section-title" style="font-size:30rpx;">卫生间</view>
    <view wx:if="{{!stationDetail.toiletLineGroups.length}}" class="empty-state" style="margin:32rpx 0 0;">暂无可展示卫生间信息</view>
    <block wx:for="{{stationDetail.toiletLineGroups}}" wx:key="lineNo">
      <view style="margin-top:24rpx;">
        <view class="chip-row">
          <view class="line-chip" style="{{item.lineChipStyle}}">{{item.lineLabel}}</view>
        </view>
        <block wx:for="{{item.entries}}" wx:key="description">
          <view class="list-card" style="margin:16rpx 0 0;">
            <view style="display:flex; align-items:center; width:100%; gap:14rpx;">
              <block wx:for="{{item.legendIcons}}" wx:key="key">
                <image class="legend-image legend-image--small" src="{{item.iconPath}}" mode="aspectFit" />
              </block>
              <view class="list-card__meta" style="margin-top:0; flex:1;">{{item.description}}</view>
              <view class="metric-pill metric-pill--success" style="flex:0 0 auto; margin-left:auto;">{{item.availabilityText}}</view>
            </view>
          </view>
        </block>
      </view>
    </block>
  </view>

  <view wx:if="{{stationDetail}}" class="panel">
    <view class="section-title" style="font-size:30rpx;">站层图</view>
    <block wx:if="{{stationDetail.floorplanGroups && stationDetail.floorplanGroups.length}}">
      <view wx:if="{{floorplanTabs.length > 1}}" class="chip-row" style="margin-top:20rpx;">
        <block wx:for="{{floorplanTabs}}" wx:key="lineNo">
          <view
            class="line-chip {{item.active ? 'line-chip--active' : ''}}"
            style="{{item.lineStyle}}"
            bindtap="handleSwitchFloorplanLine"
            data-line-no="{{item.lineNo}}"
          >
            {{item.lineLabelText}}
          </view>
        </block>
      </view>
      <block wx:for="{{visibleFloorplanGroups}}" wx:key="floorplanUrl">
        <view style="margin-top:24rpx;">
          <image
            wx:if="{{item.floorplanUrl || item.floorplanLocalPath}}"
            src="{{item.floorplanUrl || item.floorplanLocalPath}}"
            mode="widthFix"
            style="width:100%; margin-top:16rpx; border-radius:16rpx;"
          />
          <view wx:else class="empty-state" style="margin:16rpx 0 0;">该线路暂无站层图</view>
        </view>
      </block>
    </block>
    <image
      wx:elif="{{stationDetail.hasFloorplan}}"
      src="{{stationDetail.floorplanUrl || stationDetail.floorplanLocalPath}}"
      mode="widthFix"
      style="width:100%; margin-top:24rpx; border-radius:16rpx;"
    />
    <view wx:else class="empty-state">暂无站层图</view>

    <view wx:if="{{stationDetail.comments && stationDetail.comments.length}}" class="comments-card">
      <view class="section-title" style="font-size:30rpx;">共{{stationDetail.commentsCount}}条评论</view>
      <view class="comment-input-bar">{{stationDetail.draftPlaceholder}}</view>
      <block wx:for="{{stationDetail.comments}}" wx:key="id">
        <view class="comment-item">
          <view class="comment-item__header">
            <view class="comment-item__user">{{item.username}}</view>
            <view class="comment-item__time">{{item.time}}</view>
          </view>
          <view class="comment-item__content">{{item.content}}</view>
          <image wx:if="{{item.imageSrc}}" class="comment-item__image" src="{{item.imageSrc}}" mode="widthFix" />
          <view class="comment-item__actions">
            <text>{{item.replyText}}</text>
            <text>{{item.likesText}}</text>
            <text>{{item.dislikeText}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view wx:if="{{stationDetail}}" class="panel" style="padding-top:20rpx; padding-bottom:20rpx;">
    <view class="section-subtitle" style="margin-top:0;">
      卫生间信息与站层图整理自上海地铁官网，请以车站现场信息为准
    </view>
  </view>
</view>
